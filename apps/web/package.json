{
  "name": "@chat/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node ./scripts/check-bundle-budget.mjs",
    "preview": "vite preview",
    "test": "vitest run --environment jsdom",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke:join": "node ./scripts/smoke-join-room.mjs",
    "smoke:look": "node ./scripts/smoke-look-mode.mjs",
    "smoke:drawer": "node ./scripts/smoke-drawer-mode.mjs",
    "smoke:e2e": "pnpm smoke:join && pnpm smoke:look && pnpm smoke:drawer",
    "perf:sample": "node ./scripts/sample-scene-runtime.mjs",
    "assets:generate": "pnpm exec tsx ./scripts/generate-room-assets.ts"
  },
  "dependencies": {
    "@chat/protocol": "workspace:*",
    "@react-three/fiber": "^9.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "socket.io-client": "^4.8.1",
    "three": "^0.179.1"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.2.1",
    "@gltf-transform/extensions": "^4.2.1",
    "@gltf-transform/functions": "^4.2.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/three": "^0.179.0",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^26.1.0",
    "meshoptimizer": "^0.25.0",
    "playwright": "^1.55.0",
    "tsx": "^4.21.0",
    "vite": "^7.1.7"
  }
}
